---
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<nav class="mt-8 mb-4 flex flex-col md:flex-row md:justify-between items-start md:items-top">
  <div>
    <a href="/" class="hover:underline text-lg font-medium inline-block">
      {SITE_TITLE}
    </a>

    <p class="text-xs flex items-center space-x-2">
      <span>{SITE_DESCRIPTION} by</span>

      <span class="h-card flex items-center space-x-1 ml-2">
              <span class="p-note -ml-1">Aussie Product Designer in Europe</span>
              <img
                class="u-photo w-4 h-4 rounded-full"
                src="https://blog.jamesandrewscoulter.com/avatar.jpg"
                alt="James Coulter"
                width="16"
                height="16"
              />
              <a
                class="p-name u-url u-uid"
                rel="me"
                href="https://blog.jamesandrewscoulter.com/"
              >
                James Coulter
              </a>
            </span>

      <span>
          <a href="https://github.com/james-andrews-coulter" rel="me" aria-label="GitHub" class="inline-flex">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.04-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.49 1 .11-.77.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.11-3.18 0 0 1-.32 3.29 1.23.97-.27 1.99-.41 3.01-.4 1.02 0 2.04.14 3.01.4 2.29-1.55 3.29-1.23 3.29-1.23.65 1.66.25 2.86.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.6-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22 0 1.6-.02 2.89-.02 3.29 0 .32.21.69.83.57C20.56 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0Z"/>
                  </svg>
                </a>
      </span>
    </p>


  </div>
</nav>
